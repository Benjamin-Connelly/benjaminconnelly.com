{% extends "base.html.j2" %}

{% block title %}{{ title }} - Benjamin Connelly{% endblock %}
{% block description %}Research by Benjamin Connelly: rethinking texture transfer tools with 3D-printed TPU and gyroid geometry for decorative concrete, drywall repair, and ceramics.{% endblock %}
{% block canonical %}https://benjaminconnelly.com/research/{% endblock %}
{% block og_type %}article{% endblock %}
{% block og_title %}{{ title }} — Benjamin Connelly{% endblock %}
{% block og_description %}Rethinking texture transfer tools: 3D-printed TPU + gyroid geometry for concrete, drywall, and ceramics.{% endblock %}
{% block og_url %}https://benjaminconnelly.com/research/{% endblock %}

{% block head_extra %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title }}",
  "description": "Rethinking texture transfer tools with 3D-printed TPU and gyroid geometry.",
  "url": "https://benjaminconnelly.com/research/",
  "author": { "@type": "Person", "name": "Benjamin Connelly", "url": "https://benjaminconnelly.com/" },
  "publisher": { "@type": "Person", "name": "Benjamin Connelly" }
}
</script>
{% endblock %}

{% block content %}
<div class="index-content">
    {{ content }}
</div>
{% endblock %}
