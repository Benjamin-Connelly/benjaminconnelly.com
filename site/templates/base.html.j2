<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Benjamin Connelly{% endblock %}</title>
    <meta name="description" content="{% block description %}Benjamin Connelly — engineer, builder, tinkerer. Canvas gallery and research notes.{% endblock %}">
    <meta name="author" content="Benjamin Connelly">
    <meta name="theme-color" content="#000080">
    <link rel="canonical" href="{% block canonical %}https://benjaminconnelly.com/{% endblock %}">
    <meta property="og:site_name" content="benjaminconnelly.com">
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:title" content="{% block og_title %}Benjamin Connelly{% endblock %}">
    <meta property="og:description" content="{% block og_description %}Engineer, builder, tinkerer. Canvas gallery and research notes.{% endblock %}">
    <meta property="og:url" content="{% block og_url %}https://benjaminconnelly.com/{% endblock %}">
    <meta property="og:image" content="{% block og_image %}https://benjaminconnelly.com/img/og-home.png{% endblock %}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ self.og_title() }}">
    <meta name="twitter:description" content="{{ self.og_description() }}">
    <meta name="twitter:image" content="{{ self.og_image() }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&text=ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789%20%2C%2E%3A%3B%21%3F%2D%5B%5D%28%29%2F%25%26%2A%2B%3D%23%40_%22%27%E2%96%B6%E2%95%B6%25%7C&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/retro.css">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='44' fill='white' stroke='black' stroke-width='3'/><g fill='black'><polygon points='50,50 39,34 50,18 61,34'/><polygon points='50,50 39,34 50,18 61,34' transform='rotate(120 50 50)'/><polygon points='50,50 39,34 50,18 61,34' transform='rotate(240 50 50)'/></g></svg>">
    {% block head_extra %}{% endblock %}
</head>
<body>
    <div class="marquee-container">
        <div class="marquee-text">
            *** Welcome to benjaminconnelly.com *** Engineer // Builder // Tinkerer *** Now with 100% more SSL ***
        </div>
    </div>

    <nav class="navbar">
        <a href="/" class="nav-btn">Home</a>
        <span class="nav-sep">|</span>
        <a href="/research/" class="nav-btn">Research</a>
        <span class="nav-sep">|</span>
        <a href="https://github.com/benjamin-connelly" class="nav-btn">GitHub</a>
    </nav>

    <div class="page-frame">
        <div class="content-area">
            {% block content %}{% endblock %}
        </div>
    </div>

    <div class="visitor-counter">
        <span class="counter-label">Visitors:</span>
        <span class="counter-digits" id="visitor-counter">36,218,042,113,697</span>
    </div>

    <footer class="site-footer">
        <p>Best viewed at 800x600 | No cookies. No trackers.</p>
    </footer>

    <script>
    (function() {
        var el = document.getElementById('visitor-counter');
        var base = 36218042113697;
        var rate = 100000 / 1000;
        var start = Date.now();
        function fmt(n) {
            return n.toLocaleString('en-US');
        }
        function tick() {
            var elapsed = Date.now() - start;
            var current = Math.floor(base + (elapsed * rate));
            el.textContent = fmt(current);
        }
        tick();
        // Advances at ~100 counts/sec — RAF would burn 60 frames/sec for a
        // value that only changes every ~10 ms. setInterval is plenty.
        // Respect prefers-reduced-motion: render once and hold the number still.
        var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!reduced) setInterval(tick, 100);
    })();
    </script>
</body>
</html>
